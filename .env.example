# ===========================================
# SkyRoute Environment Configuration
# ===========================================
# Copy this file to .env and update values

# PostgreSQL Database
POSTGRES_USER=skyroute
POSTGRES_PASSWORD=skyroute_secret
POSTGRES_DB=skyroute_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3000
NODE_ENV=development

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000

# External APIs (Sprint 2)
# AVIATIONSTACK_API_KEY=your_aviationstack_key
# AIRLABS_API_KEY=your_airlabs_key
